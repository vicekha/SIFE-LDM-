{
    "model": {
        "embed_dim": 768,
        "num_heads": 12,
        "num_blocks": 12,
        "dropout_rate": 0.1,
        "max_seq_len": 4096
    },
    "diffusion": {
        "num_timesteps": 1000,
        "beta_start": 0.0001,
        "beta_end": 0.02,
        "schedule": "cosine",
        "prediction_type": "epsilon",
        "clip_denoised": true
    },
    "sife": {
        "m": 1.0,
        "k": 1.5,
        "alpha": 0.25,
        "beta": 1.0,
        "gamma": 0.15,
        "lambda_res": 0.5,
        "h": 1.0,
        "dt": 0.01
    },
    "multiscale": {
        "num_levels": 4,
        "base_features": 128,
        "feature_multipliers": [1, 2, 4, 8],
        "lattice_spacings": [1.0, 2.0, 4.0, 8.0],
        "time_scales": [0.01, 0.02, 0.04, 0.08],
        "coupling_strengths": [0.1, 0.1, 0.1, 0.05],
        "attention_levels": [false, false, true, true]
    },
    "training": {
        "batch_size": 128,
        "learning_rate": 0.0003,
        "weight_decay": 0.01,
        "warmup_steps": 2000,
        "max_steps": 500000,
        "gradient_accumulation_steps": 4,
        "mixed_precision": true
    },
    "data": {
        "vocab_size": 50000,
        "min_freq": 2,
        "max_seq_len": 4096
    }
}
