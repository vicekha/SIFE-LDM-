{
    "model_type": "vision",
    "model": {
        "embed_dim": 256,
        "num_heads": 8,
        "num_blocks": 6,
        "dropout_rate": 0.1,
        "max_seq_len": 256,
        "is_image": true,
        "image_size": [32, 32],
        "image_channels": 3,
        "patch_size": 4,
        "num_classes": 10
    },
    "diffusion": {
        "num_timesteps": 1000,
        "beta_start": 0.0001,
        "beta_end": 0.02,
        "schedule": "cosine",
        "prediction_type": "epsilon",
        "clip_denoised": true
    },
    "sife": {
        "m": 1.0,
        "k": 1.0,
        "alpha": 0.1,
        "beta": 1.0,
        "gamma": 0.05,
        "lambda_res": 0.3,
        "h": 1.0,
        "dt": 0.01
    },
    "multiscale": {
        "num_levels": 3,
        "base_features": 64,
        "feature_multipliers": [1, 2, 4],
        "lattice_spacings": [1.0, 2.0, 4.0],
        "time_scales": [0.01, 0.02, 0.04],
        "coupling_strengths": [0.1, 0.1, 0.05],
        "attention_levels": [false, true, true]
    },
    "training": {
        "batch_size": 64,
        "learning_rate": 0.0002,
        "weight_decay": 0.01,
        "warmup_steps": 2000,
        "max_steps": 200000,
        "gradient_accumulation_steps": 1,
        "mixed_precision": true
    },
    "data": {
        "image_size": [32, 32],
        "num_classes": 10
    }
}
